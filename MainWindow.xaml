<Window x:Class="EQMightPatcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EQ Might Patcher"
        Icon="assets/eqm-icon.png"
        Width="600" Height="660"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="PatcherButton" TargetType="Button">
            <Setter Property="Background" Value="#CC1a1a2e"/>
            <Setter Property="Foreground" Value="#FFe0c97f"/>
            <Setter Property="BorderBrush" Value="#FF8a6a1e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC2a2a4e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CC0a0a1e"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#99000000"/>
            <Setter Property="Foreground" Value="#FFe0c97f"/>
            <Setter Property="BorderBrush" Value="#FF8a6a1e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#FFe0c97f"/>
            <Setter Property="SelectionBrush" Value="#FF8a6a1e"/>
        </Style>
    </Window.Resources>

    <!-- Root with drop shadow -->
    <Border CornerRadius="8" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.8"/>
        </Border.Effect>
        <Border CornerRadius="8" ClipToBounds="True">
            <Grid>
                <Rectangle Fill="#EE0d0d1a"/>

                <DockPanel LastChildFill="True">
                    <!-- Title bar -->
                    <Border DockPanel.Dock="Top" Background="#DD0a0a14" Height="36"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Button Content="✕" Width="36" Height="36" HorizontalAlignment="Right"
                                Style="{StaticResource PatcherButton}"
                                BorderThickness="0" Background="Transparent"
                                Click="CloseButton_Click"/>
                    </Border>

                    <!-- Logo banner -->
                    <Border DockPanel.Dock="Top" Background="#CC000000"
                            BorderBrush="#FF8a6a1e" BorderThickness="0,0,0,1">
                        <Image Source="assets/logo.png" Stretch="Uniform" MaxHeight="110"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>

                    <!-- Derpdog credit link (bottom-left) -->
                    <Border DockPanel.Dock="Bottom" HorizontalAlignment="Left"
                            Background="Transparent" Cursor="Hand" Margin="8,0,0,6"
                            MouseLeftButtonUp="DerpdogLink_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="assets/derpdog.png" Width="28" Height="28"
                                   VerticalAlignment="Center" Margin="0,0,5,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="github.com/DerpleDude" Foreground="#FF9a8a60"
                                       FontFamily="Segoe UI" FontSize="10"
                                       VerticalAlignment="Center" TextDecorations="Underline"/>
                        </StackPanel>
                    </Border>

                    <!-- Content -->
                    <DockPanel Margin="20,14,20,14" LastChildFill="True">

                        <!-- Fixed top section -->
                        <StackPanel DockPanel.Dock="Top">

                            <!-- EQ Directory -->
                            <TextBlock Text="EverQuest Directory" Foreground="#FFc0a050"
                                       FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="EQDirTextBox" Grid.Column="0"
                                         Style="{StaticResource ConfigTextBox}"
                                         TextChanged="EQDirTextBox_TextChanged"/>
                                <Button Grid.Column="2" Content="Browse..." Width="72"
                                        Style="{StaticResource PatcherButton}"
                                        Click="BrowseButton_Click"/>
                            </Grid>

                            <!-- Patch Notes (below EQ dir) -->
                            <TextBlock Text="Patch Notes" Foreground="#FFc0a050"
                                       FontFamily="Segoe UI Semibold" FontSize="11" Margin="0,10,0,4"/>
                            <Border Height="100" Background="#88000000" BorderBrush="#FF8a6a1e"
                                    BorderThickness="1" CornerRadius="3" Margin="0,0,0,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled" Padding="8,6">
                                    <TextBlock x:Name="PatchNotesText"
                                               Foreground="#FFd0c090" FontFamily="Consolas" FontSize="11"
                                               TextWrapping="Wrap" LineHeight="18"
                                               Text="No patch notes available."/>
                                </ScrollViewer>
                            </Border>

                            <Separator Background="#44e0c97f" Margin="0,0,0,12"/>

                            <!-- Action button + progress -->
                            <Button x:Name="ActionButton" Content="Check for Updates"
                                    Style="{StaticResource PatcherButton}"
                                    HorizontalAlignment="Stretch" Height="36"
                                    Click="ActionButton_Click"/>
                            <ProgressBar x:Name="ProgressBar" Height="8" Margin="0,10,0,0"
                                         Minimum="0" Maximum="1" Value="0"
                                         Background="#44000000" Foreground="#FFe0c97f"
                                         BorderBrush="#FF8a6a1e" BorderThickness="1"/>
                            <TextBlock x:Name="StatusText" Foreground="#FF9a8a60"
                                       FontFamily="Segoe UI" FontSize="11" Margin="0,4,0,10"
                                       Text="" TextTrimming="CharacterEllipsis"/>

                            <Separator Background="#44e0c97f" Margin="0,0,0,12"/>

                            <!-- 3 placeholder buttons -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="PlaceholderButton1" Content="Play EQMight"
                                        Style="{StaticResource PatcherButton}" Height="32"
                                        IsEnabled="False" Click="PlaceholderButton1_Click"/>
                                <Button Grid.Column="2" x:Name="PlaceholderButton2" Content="Install 4GB Patch"
                                        Style="{StaticResource PatcherButton}" Height="32"
                                        Click="PlaceholderButton2_Click"/>
                                <Button Grid.Column="4" x:Name="PlaceholderButton3" Content="Optimization Tips"
                                        Style="{StaticResource PatcherButton}" Height="32"
                                        Click="PlaceholderButton3_Click"/>
                            </Grid>

                            <!-- Patch Status label -->
                            <TextBlock Text="Patch Status" Foreground="#FFc0a050"
                                       FontFamily="Segoe UI Semibold" FontSize="11" Margin="0,0,0,4"/>
                        </StackPanel>

                        <!-- Download log (fills remaining space) -->
                        <Border Background="#88000000" BorderBrush="#FF8a6a1e"
                                BorderThickness="1" CornerRadius="3">
                            <ScrollViewer x:Name="LogScroller"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="8,6">
                                <ItemsControl x:Name="LogItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#FFd0c090"
                                                       FontFamily="Consolas" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                    </DockPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Border>
</Window>
